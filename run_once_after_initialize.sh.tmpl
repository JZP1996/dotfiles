{{ if ne .chezmoi.os "windows" -}}
#!/bin/sh
# Per-machine initialization for macOS/Linux. Runs once; idempotent.
set -eu

# Install Oh My Zsh (non-interactive, keep existing ~/.zshrc).
if [ ! -d "$HOME/.oh-my-zsh" ]; then
  RUNZSH=no KEEP_ZSHRC=yes sh -c \
    "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" \
    "" --unattended
fi

# Install zsh plugins into ~/.zsh (paths match ~/.zsh/.zshrc.common).
ZSH_DIR="$HOME/.zsh"
mkdir -p "$ZSH_DIR"
[ -d "$ZSH_DIR/zsh-autosuggestions" ] || \
  git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions "$ZSH_DIR/zsh-autosuggestions"
[ -d "$ZSH_DIR/zsh-syntax-highlighting" ] || \
  git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_DIR/zsh-syntax-highlighting"

# Ensure ~/.zshrc sources the common chezmoi-managed config (~/.zsh/.zshrc.common).
ZSHRC="$HOME/.zshrc"
SRC_LINE='[[ -f ~/.zsh/.zshrc.common ]] && source ~/.zsh/.zshrc.common'

[ -f "$ZSHRC" ] || touch "$ZSHRC"

if ! grep -qF '.zsh/.zshrc.common' "$ZSHRC"; then
  printf '%s\n\n%s\n' "$SRC_LINE" "$(cat "$ZSHRC")" > "$ZSHRC"
fi
{{ end -}}
