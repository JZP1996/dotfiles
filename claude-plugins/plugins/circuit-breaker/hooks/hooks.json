{
  "description": "Track consecutive identical tool failures (PostToolUse) and block further attempts after 3 (PreToolUse). Allowlists transient errors (429, ETIMEDOUT, DNS).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook-post.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook-pre.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
